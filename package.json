{
  "name": "wolffish-mobile",
  "version": "1.0.1",
  "license": "MIT",
  "description": "The official mobile app for Wolffish, the personal AI agent that runs on your machine.",
  "main": "expo-router/entry",
  "author": "Younes Alturkey <younes@wolffi.sh>",
  "homepage": "https://wolffi.sh",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "expo start",
    "ios": "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 expo run:ios",
    "ios:device": "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 expo run:ios --device",
    "web": "expo start --web",
    "release": "node scripts/release.js",
    "ts:check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,css,json}\" --ignore-path .gitignore",
    "ios:prod": "EAS_BUILD_NO_EXPO_GO_WARNING=true eas build -p ios --profile production",
    "ios:submit": "eas submit -p ios",
    "test": "jest",
    "provision": "node scripts/provision.js",
    "android": "expo run:android",
    "android:preview": "EAS_BUILD_NO_EXPO_GO_WARNING=true eas build -p android --profile preview",
    "android:prod": "EAS_BUILD_NO_EXPO_GO_WARNING=true eas build -p android --profile production",
    "android:submit": "eas submit -p android --profile production"
  },
  "dependencies": {
    "@expo/ui": "~57.0.7",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tanstack/query-async-storage-persister": "^5.101.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-persist-client": "^5.101.2",
    "expo": "~57.0.7",
    "expo-blur": "~57.0.2",
    "expo-constants": "~57.0.6",
    "expo-device": "~57.0.1",
    "expo-font": "~57.0.1",
    "expo-glass-effect": "~57.0.1",
    "expo-image": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-localization": "~57.0.1",
    "expo-router": "~57.0.7",
    "expo-splash-screen": "~57.0.4",
    "expo-status-bar": "~57.0.1",
    "expo-symbols": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "expo-web-browser": "~57.0.1",
    "i18next": "^26.3.6",
    "jest": "~29.7.0",
    "jest-expo": "~57.0.2",
    "nativewind": "^4.2.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "^17.0.10",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/jest": "~29.5.14",
    "@types/react": "~19.2.2",
    "prettier": "^3.9.5",
    "reactotron-react-native": "^5.2.0",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.3"
  },
  "jest": {
    "preset": "jest-expo",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  }
}
